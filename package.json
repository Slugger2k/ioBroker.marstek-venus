{
  "name": "iobroker.marstek-venus",
  "version": "0.2.0",
  "description": "ioBroker adapter for Marstek Venus A/C/D/E energy storage devices",
  "author": "Slugger2k",
  "homepage": "https://github.com/Slugger2k/ioBroker.marstek-venus",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "marstek",
    "venus",
    "battery",
    "energy storage",
    "solar",
    "inverter"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Slugger2k/ioBroker.marstek-venus.git"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@iobroker/types": "^7.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.20.0",
    "nyc": "^18.0.0",
    "typescript": "^6.0.3"
  },
  "main": "main.js",
  "files": [
    "admin/",
    "lib/",
    "main.js",
    "io-package.json"
  ],
  "scripts": {
    "test": "npm run test:package && npm run test:unit",
    "release": "release-script",
    "test:package": "mocha test/package.test.js --exit",
    "test:unit": "mocha \"test/*.test.js\" --exit",
    "test:integration": "mocha test/integration.test.js --exit 2>/dev/null || true",
    "coverage": "nyc npm run test",
    "coverage:report": "nyc report --reporter=text --reporter=lcov --reporter=html",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "translate": "translate-adapter"
  },
  "nyc": {
    "all": true,
    "include": [
      "main.js",
      "lib/adapter.js",
      "lib/control.js",
      "lib/discovery.js",
      "lib/polling.js",
      "lib/request-queue.js"
    ],
    "exclude": [
      "test/**",
      "node_modules/**",
      "admin/**",
      "lib/adapter-config.js"
    ],
    "reporter": [
      "text",
      "text-summary",
      "html"
    ],
    "check-coverage": true,
    "branches": 70,
    "functions": 80,
    "lines": 90,
    "statements": 90,
    "extension": [
      ".js"
    ],
    "sourceMap": false,
    "instrument": true
  }
}
