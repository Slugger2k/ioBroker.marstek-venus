{
  "type": "panel",
  "items": {
    "_header": {
      "type": "header",
      "text": "Marstek Venus Configuration",
      "size": 2
    },
    "_info": {
      "type": "staticText",
      "label": "Pre-requirements: Enable Open API in the official Marstek mobile app first, note the configured UDP port (default: 30000), and ensure device and ioBroker are on the same local network.",
      "newLine": true
    },
    "ipAddress": {
      "type": "text",
      "label": "Device IP Address",
      "placeholder": "192.168.1.xxx",
      "sm": 6,
      "newLine": true
    },
    "udpPort": {
      "type": "number",
      "label": "UDP Port",
      "min": 1,
      "max": 65535,
      "default": 30000,
      "sm": 6
    },
    "pollInterval": {
      "type": "number",
      "label": "Poll interval (ms)",
      "min": 500,
      "max": 60000,
      "default": 10000,
      "sm": 6,
      "newLine": true
    },
    "autoDiscovery": {
      "type": "checkbox",
      "label": "Auto discover devices on network",
      "default": true,
      "sm": 6
    },
    "_discoverBtn": {
      "type": "sendTo",
      "command": "discover",
      "result": {
        "success": {"en": "Device discovered successfully"},
        "noDevice": {"en": "No device found"},
        "error": {"en": "Discovery failed"}
      },
      "error": {
        "timeout": {"en": "Discovery timeout"}
      },
      "label": "Discover Devices",
      "icon": "search",
      "newLine": true
    }
  }
}